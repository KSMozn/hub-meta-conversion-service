APP_ENV=local
LOG_LEVEL=INFO

# Postgres
DATABASE_URL=postgresql+psycopg://hub:hub@localhost:5432/hub

# Meta API (simulated locally)
META_API_BASE_URL=https://graph.facebook.com/v20.0
META_API_TIMEOUT_SECONDS=15
META_USE_MOCK=true
META_MOCK_FAIL_RATE=0.0
META_MOCK_RATE_LIMIT_EVERY=0

# OAuth2 client (used by the OAuth refresh simulator)
META_OAUTH_CLIENT_ID=local-client-id
META_OAUTH_CLIENT_SECRET=local-client-secret

# Encryption-at-rest key for OAuth tokens (Fernet-style, 32 url-safe base64 bytes)
TOKEN_ENCRYPTION_KEY=changeme-changeme-changeme-changeme=

# Retry / backoff
META_MAX_RETRIES=4
META_RETRY_BASE_DELAY_SECONDS=0.5
